import { LoaderArea, LoadingSpinner } from "../../utils/loader-area.slint";
import { SelectionIndicator } from "../../components/selection-indicator.slint";
import { Theme } from "theme.slint";
import { AccordionHeader } from "components/accordion-header.slint";
import { SideBarItem } from "components/side-bar-item.slint";
import { EnvsLoading, EnvironmentsFeatureGlobal } from "globals.slint";
import { Icons } from "icons.slint";
import { L10n } from "localization.slint";

export component DistroItem inherits Rectangle {
    in-out property <string> name;
    in-out property <bool> active;
    in-out property <bool> installed;
    in-out property <bool> running;

    callback clicked;
    callback install_clicked;

    height: 36px;
    border-radius: Theme.border_radius_s;

    background: active ? Theme.item_active_background : (touch.has-hover ? Theme.fill_subtle_hover : transparent);
    animate background { duration: Theme.primary_animation_time; }

    touch := TouchArea {
        enabled: root.installed;
        mouse-cursor: pointer;
        clicked => {
            if (root.installed) {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        padding-left: 54px;
        padding-right: 8px;
        spacing: 8px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: Theme.border_radius_s;
                background: !root.installed ? Theme.disabled : (root.running ? Theme.success : Theme.offline);
                animate background { duration: Theme.primary_animation_time; }
            }
        }

        Text {
            text: root.name;

            font-size: Theme.font_size_caption;
            vertical-alignment: center;
            horizontal-stretch: 1;
            color: !root.installed ? Theme.text_disabled : (active ? Theme.text_primary : Theme.text_secondary);

            animate color { duration: Theme.primary_animation_time; }
        }

        if (!root.installed): Rectangle {
            width: 24px;
            height: 24px;
            border-radius: Theme.border_radius_s;
            background: install-touch.has-hover ? Theme.fill_subtle_hover : transparent;

            Image {
                source: Icons.download-regular;
                width: 16px;
                height: 16px;
                colorize: install-touch.has-hover ? Theme.accent : Theme.text_secondary;
                animate colorize { duration: Theme.primary_animation_time; }
            }

            install-touch := TouchArea {
                clicked => {
                    root.install_clicked();
                }
            }
        }
    }
}

export component Environments inherits VerticalLayout {

    spacing: 2px;

    Rectangle {
        background: Theme.layer_background;
        border-radius: 6px;
        VerticalLayout {
            spacing: 2px;
            env_main := AccordionHeader {
                text: L10n.environments;
                icon: Icons.coin;
                open: true;
                is-loading: EnvsLoading.wsl-is-loading;
            }

            if (env_main.open): VerticalLayout {
                spacing: 2px;

                SideBarItem {
                    text: EnvironmentsFeatureGlobal.host-name;
                    icon: EnvironmentsFeatureGlobal.host-icon;
                    active: EnvironmentsFeatureGlobal.selected-env == EnvironmentsFeatureGlobal.host-name;
                    colorize: false;
                    clicked => {
                        EnvironmentsFeatureGlobal.selected-env = EnvironmentsFeatureGlobal.host-name;
                    }
                }

                if (EnvironmentsFeatureGlobal.has-wsl): Rectangle {

                    VerticalLayout {
                        spacing: 2px;

                        wsl_sub := AccordionHeader {
                            text: "WSL";
                            icon: Icons.wsl;
                            open: true;
                            is-loading: EnvsLoading.wsl-distros-is-loading;
                        }

                        if (wsl_sub.open): VerticalLayout {
                            spacing: 2px;
                            for distro in EnvironmentsFeatureGlobal.wsl-distros: SideBarItem {
                                text: distro.name;
                                icon: distro.icon;
                                active: EnvironmentsFeatureGlobal.selected-env == distro.name;
                                latency-ms: distro.latency-ms;

                                clicked => {
                                    EnvironmentsFeatureGlobal.selected-env = distro.name;
                                }

                                Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: Theme.border_radius_s;
                                    x: parent.width - 24px;
                                    y: (parent.height - self.height) / 2;

                                    background: !distro.is_running ? Theme.disabled : !distro.is_installed ? Theme.offline : distro.latency_ms == -1 ? Theme.warn : Theme.success;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
