
export enum PageStatus {
    inactive,
    loading,
    ready,
    error
}

export struct PageData {
    id: int,
    text: string,
    icon: image,
    status: PageStatus,
    error_msg: string,
}

export struct TabData {
    id: int,
    title: string,
    pages: [PageData],
    status: PageStatus,
    error_msg: string,
}

